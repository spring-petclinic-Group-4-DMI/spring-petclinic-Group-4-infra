# Local .terraform directory (contains provider plugins and modules)
.terraform/

# .tfstate files (contain sensitive infrastructure data and secrets)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files by default (often contain secrets)
*.tfvars
*.tfvars.json

# Override files (local configuration overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc
.tfvars.example
.tfvars